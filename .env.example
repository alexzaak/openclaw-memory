# ============================================================================
# .env.example – Template for Clawdi AI Memory configuration
# ============================================================================
# Copy this file to .env and adjust values for your environment:
#   cp .env.example .env
# ============================================================================

# ── Services ────────────────────────────────────────────────────────────────
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
OLLAMA_URL=http://127.0.0.1:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSION=768
FALKOR_HOST=127.0.0.1
FALKOR_PORT=6379

# ── Data ────────────────────────────────────────────────────────────────────
QDRANT_COLLECTION=openclaw_memory
FALKOR_GRAPH=openclaw_ontology
SESSIONS_DIR=/home/clawdi/.openclaw/agents/main/sessions/
SQLITE_PATH=~/.openclaw/short_term.db
ONTOLOGY_FILE=/home/clawdi/.openclaw/workspace/memory/ontology/graph.jsonl

# ── Infrastructure (Podman / setup.sh) ──────────────────────────────────────
QDRANT_STORAGE=/home/clawdi/.qdrant_storage
FALKOR_STORAGE=/home/clawdi/.falkor_storage
DASHBOARD_PORT=8000

# ── Dashboard API ───────────────────────────────────────────────────────────
API_PORT=8080
CORS_ORIGINS=*

# ── Backup ──────────────────────────────────────────────────────────────────
BACKUP_DIR=~/.openclaw/backups
BACKUP_RETAIN=5
